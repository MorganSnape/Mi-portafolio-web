---
import { dataSeccionesBlog } from '@/data/blog/dataSeccionesBlog'
import Layout from '@/layouts/Layout.astro'
import DecoracionCurva from '@/icons/decoracion-curva.svg'

import { getCollection } from 'astro:content'
import Footer from '@/components/Footer.astro'

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime(),
  )

  return dataSeccionesBlog.map(seccionBlog => {
    return {
      params: { slug: seccionBlog.slug },
      props: {
        posts: posts.filter(
          post => post.data.sectionBlogId === seccionBlog.slug,
        ),
      },
    }
  })
}

const { slug } = Astro.params
const { posts } = Astro.props
const seccionBlog = dataSeccionesBlog.find(
  seccionBlog => seccionBlog.slug === slug,
)

if (!seccionBlog) {
  throw new Error('No existe el seccionBlog')
}

const { title, description, image } = seccionBlog
---

<Layout title={`Blog de ${title}`}>
  <main>
    <img
      src={image}
      alt={title}
      class="w-full object-cover object-center h-64"
    />
    <div
      class="mx-auto max-w-[1280px] px-4 sm:px-12 xl:px-0 py-20 flex flex-col gap-8"
    >
      <h1 class="text-4xl font-bold font-fantabular">{title}</h1>
      <p class="text-lg leading-6">{description}</p>
      <div class="flex flex-col gap-6">
        <div
          class="flex flex-row flex-wrap justify-center md:justify-start items-center gap-4"
        >
          <h3 class="titleH3 efectoResaltador text-balance">
            Herramientas que uso
          </h3>
          <DecoracionCurva class="w-32 lg:w-40" />
        </div>
        <ol class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            posts.map((post, index) => (
              <li class="group border-t-2 border-black-secondary py-4 px-2 list-none mb-0 transition-all duration-300 hover:bg-primary/10 hover:border-primary rounded-xl">
                <a
                  href={`/blog/${post.id}`}
                  class="flex items-center text-lg gap-4 h-full text-black font-medium transition-all duration-300 group-hover:text-primary"
                >
                  <span class="text-white text-base font-bold bg-primary rounded-full w-9 h-9 flex justify-center items-center text-center shrink-0 transition-transform duration-300 group-hover:scale-110 group-hover:shadow-lg">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <div class="flex flex-col min-w-0">
                    <span class="font-semibold leading-snug transition-colors duration-300 group-hover:text-primary">
                      {post.data.title}
                    </span>
                    <p class="text-gray-500 text-sm font-semibold mt-1">
                      Fecha de publicación:
                      {post.data.pubDate.toLocaleDateString('es-CO', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
