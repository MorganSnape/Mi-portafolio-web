---
import BarNav from "@/components/BarNav.astro";
import Footer from "@/components/Footer.astro";
import { dataSeccionesBlog } from "@/data/blog/dataSeccionesBlog";

import Layout from "@/layouts/Layout.astro";

---

<Layout title="Inicio de blog - Gabriela Ferrer">
  <BarNav />
  <main
    class="flex flex-col items-center gap-8 font-rethink select-none w-full"
  >
    <section class="min-h-screen flex flex-col items-center justify-center">
      <h1 class="text-8xl text-center font-fantabular">
        <span
          class="relative font-bold font-rethink after:bg-secondary after:-z-10 after:w-full after:absolute after:left-0 after:bottom-1 after:h-[50%]"
          >My blog personal</span
        ><br />
        <span class="italic font-fantabular font-normal">de estudios</span>
      </h1>
    </section>
    <div class="bg-asparagus-500 h-12 w-full"></div>
    <div class="mx-auto w-full max-w-[1280px] px-4 sm:px-12 xl:px-0">
      <section class="flex flex-col gap-4 py-20 w-full">
        <div class="flex flex-row w-full gap-4">
        {
          dataSeccionesBlog.map((dataBlog) => (
            <a
              href={`/blog/${dataBlog.slug}`}
              class="group relative cursor-pointer hover:scale-[1.02] transition-all duration-300 ease-out aspect-square w-72 bg-white min-h-64 border-2 border-black rounded-xl md:rounded-2xl overflow-hidden shadow-sm hover:shadow-xl"
            >
              <div class="h-10 bg-white flex flex-row items-center gap-2 px-4 border-b-4 border-black rounded-t-xl md:rounded-t-2xl">
                <div class="h-3 w-3 bg-black rounded-full" />
                <div class="h-3 w-3 bg-black rounded-full" />
                <div class="h-3 w-3 bg-black rounded-full" />
              </div>
              <img
                src={dataBlog.image}
                alt={`Imagen de ${dataBlog.title}`}
                class="h-full w-full object-cover object-center transition-transform duration-300 ease-out group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/35 to-transparent opacity-0 transition-all duration-300 ease-out group-hover:opacity-100" />
              <div class="absolute inset-x-0 bottom-0 translate-y-full p-4 text-white transition-transform duration-300 ease-out group-hover:translate-y-0">
                <h2 class="font-fantabular text-xl font-semibold leading-tight">
                  {dataBlog.title}
                </h2>
                <p class="mt-2 text-sm leading-5 text-white/90 max-h-16 overflow-hidden">
                  {dataBlog.description}
                </p>
              </div>
            </a>
          ))
        }
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
