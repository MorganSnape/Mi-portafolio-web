---
import BarNav from '@/components/BarNav.astro'
import Footer from '@/components/Footer.astro'
import { dataSeccionesBlog } from '@/data/blog/dataSeccionesBlog'

import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { $brand } from 'astro:schema'
---

<Layout title="Inicio de blog - Gabriela Ferrer">
  <BarNav active={false} />
  <main
    class="flex flex-col items-center gap-8 font-rethink select-none w-full"
  >
    <section class="min-h-screen flex flex-col items-center justify-center">
      <h1 class="text-8xl text-center font-fantabular">
        <span
          class="relative font-bold font-rethink after:bg-secondary after:-z-10 after:w-full after:absolute after:left-0 after:bottom-1 after:h-[50%]"
          >My blog personal</span
        ><br />
        <span class="italic font-fantabular font-normal">de estudios</span>
      </h1>
    </section>
    <div class="bg-asparagus-500 h-12 w-full"></div>
    <div class="mx-auto w-full max-w-[1280px] px-4 sm:px-12 xl:px-0">
      <section class="flex flex-col gap-4 py-20 w-full">
        <div class="flex flex-row w-full gap-4">
          {
            dataSeccionesBlog.map(dataBlog => (
              <a
                href={`/blog/${dataBlog.slug}`}
                class="inline-block snap-start shrink-0"
              >
                <article
                  class={` group flex flex-col border-2 border-black rounded-xl md:rounded-2xl h-[360px] md:h-[400px] w-[280px] md:w-xs bg-white`}
                >
                  <div class="h-10 py-4 flex flex-row items-center gap-2 px-4 border-b-4 border-black">
                    <div class="h-3 w-3 bg-black rounded-full" />
                    <div class="h-3 w-3 bg-black rounded-full" />
                    <div class="h-3 w-3 bg-black rounded-full" />
                  </div>
                  <header class="relative w-full overflow-hidden md:flex-shrink-0 rounded-b-2xl shadow-md h-2/5">
                    <img
                      src={dataBlog.image}
                      alt={'Portada del proyecto ' + dataBlog.title}
                      class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-110"
                    />
                  </header>
                  <main class="flex flex-col p-4 justify-between w-full flex-1">
                    <h4 class="text-sm md:text-base font-medium font-fantabular">
                      {dataBlog.title}
                    </h4>
                    <p class="text-sm lg:text-base text-pretty line-clamp-3">
                      {dataBlog.description}
                    </p>
                    <div class="flex flex-row items-center justify-between">
                      {/* <div class="flex flex-wrap gap-2">
                        {tags?.slice(0, 1).map(tag => (
                          <div class="bg-secondary text-black border border-black py-0.5 px-2 md:px-4 w-fit text-xs font-semibold">
                            {tag}
                          </div>
                        ))}
                      </div> */}
                      <button class="cursor-pointer p-2 font-medium text-sm flex items-center gap-4 w-fit transition-colors duration-300 ease-in-out text-black">
                        <Icon
                          name="fa6-solid:arrow-up"
                          height={20}
                          width={20}
                          class="transition-transform ease-in-out duration-200 rotate-45 group-hover:rotate-90"
                        />
                      </button>
                    </div>
                  </main>
                </article>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
