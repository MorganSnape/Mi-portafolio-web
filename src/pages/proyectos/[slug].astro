---
import { proyectos } from "@/data/portfolio.ts";

import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import Investigacion from "@/components/PaginaDinamica/Investigacion.astro";
import DefinicionProblema from "@/components/PaginaDinamica/DefinicionProblema.astro";
import Ideacion from "@/components/PaginaDinamica/Ideacion.astro";
import Diseño from "@/components/PaginaDinamica/Diseño.astro";
import { Icon } from "astro-icon/components";
import RedesBoton from "@/components/RedesBoton.astro";
import BarNav from "@/components/PaginaDinamica/BarNav.astro";

import Estrella from "@/assets/estrella.svg";

export async function getStaticPaths() {
  return proyectos.flatMap((proyecto) => {
    return {
      params: { slug: proyecto.slug },
    };
  });
}

const { slug } = Astro.params;
const proyecto = proyectos.find((proyecto) => proyecto.slug === slug);

if (!proyecto) {
  throw new Error("No existe el proyecto");
}

const {
  nameProject,
  name,
  date,
  brandDescription,
  frontPage,
  linkFigma,
  linkWebsite,
  shortDescription,
  descriptionProject,
  objectiveBusiness,
  objectiveUser,
  testing,
  research,
  problemDefinition,
  ideation,
  visualDesign,
  tags,
  details,
} = proyecto;
---

<Layout title=`Este es el proyecto ${name}`>
  <BarNav />
  <main class="flex flex-col items-center gap-10">
    <div
      class="fixed bottom-10 right-4 md:right-10 z-50 flex flex-col md:flex-row gap-4"
    >
      {
        linkFigma && (
          <RedesBoton href={linkFigma} text="Ver Figma" block={true}>
            <Icon name="fa6-brands:figma" height={20} width={20} />
          </RedesBoton>
        )
      }
      {
        linkWebsite && (
          <RedesBoton href={linkWebsite} text="Ver Pagina" block={true}>
            <Icon name="fa6-solid:earth-americas" height={20} width={20} />
          </RedesBoton>
        )
      }
    </div>
    <section id="inicio" class="flex flex-col items-center w-full">
      <div
        class="flex flex-col gap-4 items-start w-11/12 max-w-[1120px] pb-8 pt-20"
      >
        <h1 class="titleH3 font-bold font-jost">
          {nameProject}
          <span class="text-primary">
            - {details?.find((item) => item.label === "My rol")?.value}
          </span>
        </h1>
        <p class="text-base font-medium leading-tight">
          {shortDescription}
        </p>
        <ul
          class="w-full text-black font-medium text-sm md:text-base flex flex-wrap md:flex-row items-center gap-4 py-2"
        >
          <li class="flex flex-row gap-3 items-center">
            <div
              class="h-10 w-10 rounded-full flex justify-center bg-primary overflow-hidden bg-cover bg-center border-2 border-primary"
            >
              <img
                src="/images/Foto.png"
                alt="Foto de Gabriela Ferrer usando un sueter rosa y sonriendo."
                class="w-full h-full object-cover object-top"
              />
            </div>
            <p class="font-semibold">Gabriela Ferrer</p>
          </li>
          <li class="mx-6">
            <p class="text-black text-base">
              {date}
            </p>
          </li>
          {
            tags &&
              tags.map((tag) => (
                <li class="bg-secondary text-black py-0.5 px-2 md:px-4 w-fit text-xs font-semibold border-1 border-black ">
                  {tag}
                </li>
              ))
          }
        </ul>
      </div>
      <img
        src={frontPage}
        alt={`Portada del proyecto ${name}`}
        class="h-[220px] md:h-[420px] w-full object-cover border-y-2 border-black"
      />
      <ul
        class="w-full bg-primary/12 grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-6 gap-4 pt-6 pb-2 px-4 items-start"
      >
        {
          details?.map((detail) => (
            <li class="flex flex-col justify-center gap-2 text-center">
              <div class="flex flex-row justify-center items-center gap-2 font-semibold">
                <Icon name={detail.icon} class="text-lg md:text-xl" />
                {detail.label}
              </div>
              <p class="text-sm md:text-base">{detail.value}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <div class="w-11/12 max-w-[1120px] flex flex-col gap-20 mb-8">
      <section id="acerca" class="flex flex-col gap-12">
        {
          brandDescription && (
            <p class="italic text-sm md:text-base border-l-8 border-primary pl-4">
              {brandDescription}
            </p>
          )
        }
        <div
          class="grid grid-cols-1 md:grid-cols-[400px_1fr] gap-8 md:gap-12 items-center"
        >
          <h2 class="titleProyecto">
            Contexto del <br /> proyecto
          </h2>
          <p
            class="text-balance text-sm lg:text-base font-medium whitespace-pre-wrap"
          >
            {descriptionProject}
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-40">
          <div class="flex flex-col gap-4">
            <div class="flex flex-row gap-4 items-center">
              <Estrella class="h-8 w-8" />
              <h3 class="subtituloProyecto">Objetivo del negocio</h3>
            </div>
            <p class="text-balance">
              {objectiveBusiness}
            </p>
          </div>
          <div class="flex flex-col gap-4">
            <div class="flex flex-row gap-4 items-center">
              <Estrella class="h-8 w-8" />
              <h3 class="subtituloProyecto">Objetivo del usuario</h3>
            </div>
            <p class="text-balance">
              {objectiveUser}
            </p>
          </div>
        </div>
      </section>
      {research && <Investigacion research={research} />}
      {
        problemDefinition && (
          <DefinicionProblema problemDefinition={problemDefinition} />
        )
      }
      {ideation && <Ideacion ideation={ideation} />}
      {
        testing && (
          <div class="flex flex-col gap-12">
            <h2 class="titleProyecto">Pruebas</h2>
            <p>{testing.summary}</p>
          </div>
        )
      }
    </div>
    {visualDesign && <Diseño visualDesign={visualDesign} />}
  </main>
  <Footer />
</Layout>
