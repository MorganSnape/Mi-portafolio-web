---
import { proyectos } from "@/data/portfolio.ts";

import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import Investigacion from "@/components/PaginaDinamica/Investigacion.astro";
import DefinicionProblema from "@/components/PaginaDinamica/DefinicionProblema.astro";
import Ideacion from "@/components/PaginaDinamica/Ideacion.astro";
import Diseño from "@/components/PaginaDinamica/Diseño.astro";
import { Icon } from "astro-icon/components";
import Button from "@/components/Button.astro";
import BarNav from "@/components/PaginaDinamica/BarNav.astro";

import Estrella from "@/assets/estrella.svg";

export async function getStaticPaths() {
  return proyectos.flatMap((proyecto) => {
    return {
      params: { slug: proyecto.slug },
    };
  });
}

const { slug } = Astro.params;
const proyecto = proyectos.find((proyecto) => proyecto.slug === slug);

if (!proyecto) {
  throw new Error("No existe el proyecto");
}

const {
  nameProject,
  date,
  brandDescription,
  frontPage,
  linkFigma,
  projectImagesList,
  linkWebsite,
  shortDescription,
  descriptionProject,
  objectiveBusiness,
  objectiveUser,
  testing,
  research,
  problemDefinition,
  ideation,
  visualDesign,
  tags,
  details,
} = proyecto;
---

<Layout title=`Este es el proyecto ${nameProject}`>
  <BarNav />
  <main class="flex flex-col items-center gap-20 py-20">
    <button
      id="backToTop"
      type="button"
      aria-label="Scroll projects left"
      class="fixed z-50 bottom-10 right-1/2 primaryButton bg-white rounded-full text-black p-3 cursor-pointer opacity-60 hover:opacity-1000"
    >
      <Icon name="fa6-solid:arrow-up" height={20} width={20} class="" />
    </button>
    <div
      class="fixed bottom-10 right-4 md:right-10 z-50 flex flex-col md:flex-row gap-4"
    >
      {
        linkFigma && (
          <Button href={linkFigma} text="Ver Figma" style="solid" typeIcon>
            <Icon name="fa6-brands:figma" height={20} width={20} />
          </Button>
        )
      }
      {
        linkWebsite && (
          <Button href={linkWebsite} text="Ver Pagina" style="solid" typeIcon>
            <Icon name="fa6-solid:earth-americas" height={20} width={20} />
          </Button>
        )
      }
    </div>
    <section id="inicio" class="flex flex-col items-center w-full">
      <div
        class="flex flex-col gap-4 items-start py-3 max-w-[1280px] w-full px-4 md:px-12 lg:px-0"
      >
        <h1 class="titleH3 font-bold font-fantabular">
          {nameProject}
          <span class="text-primary">
            - {details?.find((item) => item.label === "My rol")?.value}
          </span>
        </h1>
        <p class="text-lg leading-tight">
          {shortDescription}
        </p>
        <ul
          class="w-full text-black text-sm md:text-base flex flex-wrap md:flex-row items-center gap-4 py-2"
        >
          <li class="flex flex-row gap-3 items-center">
            <div
              class="h-10 w-10 rounded-full flex justify-center bg-primary overflow-hidden bg-cover bg-center border-2 border-primary"
            >
              <img
                src="/images/Foto.png"
                alt="Foto de Gabriela Ferrer usando un sueter rosa y sonriendo."
                class="w-full h-full object-cover object-top"
              />
            </div>
            <p class="font-semibold">Gabriela Ferrer</p>
          </li>
          <li class="mx-6">
            <p class="text-black text-base">
              {date}
            </p>
          </li>
          {
            tags &&
              tags.map((tag) => (
                <li class="bg-secondary text-black py-0.5 px-2 md:px-4 w-fit text-xs font-semibold border-1 border-black ">
                  {tag}
                </li>
              ))
          }
        </ul>
      </div>
      <img
        src={frontPage}
        alt={`Portada del proyecto ${nameProject}`}
        class="h-[200px] md:h-[400px] w-full object-cover object-center border-y-2 border-black"
      />
      <ul
        class="sombra w-full bg-white grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-5 gap-4 py-4 px-4 items-start"
      >
        {
          details?.map((detail) => (
            <li class="flex flex-col justify-center gap-2 text-center">
              <div class="flex flex-row justify-center items-center gap-2 font-semibold">
                <Icon name={detail.icon} class="text-lg md:text-xl" />
                {detail.label}
              </div>
              <p class="text-sm md:text-base">{detail.value}</p>
            </li>
          ))
        }
      </ul>
    </section>
    <div
      class="max-w-[1280px] w-full px-4 md:px-12 lg:px-0 flex flex-col gap-20 mb-8"
    >
      <section id="acerca" class="flex flex-col gap-12">
        {
          brandDescription && (
            <p class="italic text-sm md:text-base border-l-8 border-primary pl-4">
              {brandDescription}
            </p>
          )
        }
        <div
          class="grid grid-cols-1 md:grid-cols-[410px_1fr] gap-8 md:gap-12 items-center"
        >
          <h2 class="titleProyecto">
            Contexto del <br /> proyecto
          </h2>
          <p class="text-balance text-sm lg:text-base whitespace-pre-wrap">
            {descriptionProject}
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-40">
          <div class="flex flex-col gap-4">
            <div class="flex flex-row gap-4 items-center">
              <Estrella class="h-8 w-8" />
              <h3 class="subtituloProyecto">Objetivo del negocio</h3>
            </div>
            {
              Array.isArray(objectiveBusiness) ? (
                <ul>
                  {objectiveBusiness.map((item) => (
                    <li class="list-disc">{item}</li>
                  ))}
                </ul>
              ) : (
                <p class="text-balance">{objectiveBusiness}</p>
              )
            }
          </div>
          <div class="flex flex-col gap-4">
            <div class="flex flex-row gap-4 items-center">
              <Estrella class="h-8 w-8" />
              <h3 class="subtituloProyecto">Objetivo del usuario</h3>
            </div>
            {
              Array.isArray(objectiveUser) ? (
                <ul>
                  {objectiveUser.map((item) => (
                    <li class="list-disc">{item}</li>
                  ))}
                </ul>
              ) : (
                <p class="text-balance">{objectiveUser}</p>
              )
            }
          </div>
        </div>
      </section>

      {
        projectImagesList && (
          <div class="flex flex-col gap-0 w-4/5 mx-auto">
            {projectImagesList?.map((img: any) => (
              <img src={img.default.src} alt="" />
            ))}
          </div>
        )
      }

      {research && <Investigacion research={research} />}
      {
        problemDefinition && (
          <DefinicionProblema problemDefinition={problemDefinition} />
        )
      }
      {ideation && <Ideacion ideation={ideation} />}
      {
        testing && (
          <div class="flex flex-col gap-12">
            <h2 class="titleProyecto">Pruebas</h2>
            <p>{testing.summary}</p>
          </div>
        )
      }
    </div>
    {visualDesign && <Diseño visualDesign={visualDesign} />}
  </main>
  <Footer />
</Layout>

<script>
  const button = document.getElementById("backToTop");

  button?.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });
</script>
