---
import Layout from "../layouts/Layout.astro";
import { personalInfo } from "../data/personal";
import { estudios } from "../data/studies";
---

<Layout title="Currículum - Gabriela Ferrer">
  <div class="bg-primary/20 text-sm print:font-normal font-normal">
    <article
      class="max-w-4xl mx-auto p-12 print:p-4 bg-white flex flex-col gap-8"
    >
      <section class="flex gap-5 flex-col">
        <div class="text-center pb-5 border-b-3 border-primary">
          <div>
            <h1 class="font-semibold text-3xl text-black mb-4 font-fantabular">
              {personalInfo.name}
            </h1>
            <p class="text-lg font-medium font-rethink">{personalInfo.title}</p>
          </div>
        </div>
        <div class="flex flex-col gap-5 justify-center items-center">
          <h2 class="font-bold text-xl mb-2">Resumen Profesional</h2>
          <p class="text-black text-pretty text-center whitespace-pre-line">
            {personalInfo.summary}
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <div class="grid md:grid-cols-2 col-span-1 print:grid-cols-2 gap-6">
            <div class="space-y-3 text-black">
              <span class="font-bold text-primary">Teléfono:</span>
              <p>
                {personalInfo.phone}
              </p>
            </div>
            <div>
              <span class="font-bold text-primary">Email:</span>
              <p>
                {personalInfo.email}
              </p>
            </div>
          </div>
          <div class="grid md:grid-cols-2 col-span-1 print:grid-cols-2 gap-6">
            <a
              href={personalInfo.linkedin}
              class="text-primary hover:text-black transition-colors"
            >
              <span class="font-bold">LinkedIn:</span>
              <p class="text-black">{personalInfo.linkedin}</p>
            </a>
            <a
              href={personalInfo.website}
              class="text-primary hover:text-black transition-colors"
            >
              <span class="font-bold">Portafolio Web:</span>
              <p class="text-black">{personalInfo.website}</p>
            </a>
          </div>
          <div class="grid md:grid-cols-2 col-span-1 print:grid-cols-2 gap-6">
            <a
              href={personalInfo.behance}
              class="text-primary hover:text-black transition-colors"
            >
              <span class="font-bold break-words">Behane:</span>
              <p class="text-black">{personalInfo.behance}</p>
            </a>
            <a
              href={personalInfo.github}
              class="text-primary hover:text-black transition-colors"
            >
              <span class="font-bold">Git Hub:</span>
              <p class="text-black">{personalInfo.github}</p>
            </a>
          </div>
        </div>
      </section>

      <!-- Experiencia Profesional -->
      <section class="flex flex-col gap-6 print:break-inside-avoid">
        <h2
          class="font-bold text-xl pb-4 text-black border-b-3 border-primary"
        >
          Experiencia Profesional
        </h2>
        {
          personalInfo.experiences?.map((experience) => (
            <div class="flex flex-row items-start gap-6 px-0">
              <div class="flex flex-row gap-2 items-center">
                <p class="text-black font-medium font-fantabular w-26">
                  {experience.date}
                </p>
                <div class="h-0.5 bg-black w-8" />
              </div>

              <article class="flex flex-col gap-6">
                <header>
                  <h4 class="font-medium font-fantabular text-lg w-fit">
                    {experience.position} - {experience.company}
                  </h4>
                </header>
                <main>
                  <ul class="space-y-1">
                    {experience.description?.map((desc) => (
                      <li class="list-disc list-outside pl-2">
                        {desc}
                      </li>
                    ))}
                  </ul>
                </main>
                <div class="">
                  <span class="font-bold text-primary">Referencias:</span>
                  <p>{experience.reference}</p>
                </div>
              </article>
            </div>
          ))
        }
      </section>

      <!-- Educación -->
      <section class="mb-12 print:break-before-page">
        <h2
          class="font-bold text-xl mb-6 pb-4 text-black border-b-3 border-primary"
        >
          Educación
        </h2>
        <div class="space-y-8">
          {
            estudios.map((estudio) => (
              <div class="border-l-3 border-primary/40 pl-6 print:break-inside-avoid">
                <h3 class="font-fantabular font-medium text-base text-black">
                  {estudio.title} | {estudio.duration}
                </h3>
                <p class=" font-medium mb-3 text-primary italic  ">
                  {estudio.institution}
                </p>
                <ul class="text-black ml-6">
                  {estudio.descriptions.map((desc) => (
                    <li class="list-disc mb-1">{desc}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Idiomas -->
      {
        personalInfo.languages && (
          <section class="mb-12 print:break-inside-avoid">
            <h2 class="font-bold text-xl mb-6 pb-4 text-black border-b-3 border-primary">
              Idiomas
            </h2>
            <div class="flex flex-wrap gap-4">
              {personalInfo.languages.map((language) => (
                <span>{language}</span>
              ))}
            </div>
          </section>
        )
      }

      <!-- Habilidades Técnicas -->
      <section class="mb-12 print:break-inside-avoid">
        <h2
          class="font-bold text-xl mb-6 pb-4 text-black border-b-3 border-primary"
        >
          Habilidades Técnicas
        </h2>
        <ul class="ml-5">
          {
            personalInfo.skills.map((skill) => (
              <li class="list-disc mb-1">{skill}</li>
            ))
          }
        </ul>
      </section>

      <!-- Habilidades Blandas -->
      <section class="mb-12 print:break-inside-avoid pb-12">
        <h2
          class="font-bold text-xl mb-6 pb-4 text-black border-b-3 border-primary"
        >
          Habilidades Blandas
        </h2>
        <ul class="ml-5">
          {
            personalInfo.softSkills?.map((skill) => (
              <li class="list-disc mb-1">{skill}</li>
            ))
          }
        </ul>
      </section>
    </article>

    <!-- Botón de descarga -->
    <div class="text-center mt-12 print:hidden fixed bottom-12 right-12">
      <button
        onclick="window.print()"
        class="primaryButton bg-primary text-white px-6 py-3 font-medium"
      >
        Descargar como PDF
      </button>
    </div>
  </div>
</Layout>

<style>
  @media print {
    body {
      -webkit-print-color-adjust: exact; /* Chrome, Safari, Edge */
      print-color-adjust: exact; /* Firefox */
      user-select: text !important;
      -webkit-user-select: text !important;
    }
    .print\\:hidden {
      display: none;
    }
    .border-l-4 {
      border-left-width: 4px;
    }
    .border-b-2 {
      border-bottom-width: 2px;
    }
  }
  a {
    z-index: 99;
  }
</style>
