---
import "@/styles/global.css";
import Footer from "@/components/Footer.astro";

const {
  title,
  headerTitle = "Blog de Gabriela",
  img = "/images/tarjeta-presentacion.webp",
  description = "Aprendiendo JavaScript con ternura",
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <style lang="scss"></style>
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="text-black font-sans min-h-screen flex flex-col ">
    <header>
      <div
        class="relative h-40 p-6 text-black shadow-md overflow-hidden"
      >
        <img
          src={img}
          alt="Fondo bonito"
          class="absolute inset-0 object-cover w-full h-full -z-10 brightness-75"
        />
      </div>
      <div class="max-w-7xl w-11/12 mx-auto">
        <h1 class="text-3xl font-bold">{headerTitle}</h1>
        <p class="text-sm italic">{description}</p>
      </div>
    </header>
    <div class="flex flex-row w-11/12 max-w-7xl mx-auto mt-6 gap-6">
      <aside class="bg-primary p-4">
      </aside>
      <main class="flex-1 min-h-screen">
        <slot />
      </main>

    </div>
    <Footer/>
    <script>
      const titles = document.querySelectorAll("h2");
      const arrTitles = [];
      titles.forEach((title) => {
        const { id, textContent: text, tagName } = title;

        arrTitles.push({ id, text, tagName });
        console.log(title.tagName, title.textContent, title.id);
      });
    </script>
  </body>
</html>
