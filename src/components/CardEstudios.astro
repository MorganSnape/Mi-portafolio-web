---
import type { Studies } from "@/models";

interface Props extends Studies {}

const { title, descriptions, link, tags, institution, duration, logo } =
  Astro.props;
---

<article
  class="group flex flex-col border-2 border-black rounded-xl md:rounded-2xl overflow-hidden h-full w-full bg-white flex-shrink-0 mx-auto"
>
  <div
    class="h-10 py-4 flex flex-row items-center gap-2 px-4 border-b-4 border-black"
  >
    <div class="h-3 w-3 bg-black rounded-full"></div>
    <div class="h-3 w-3 bg-black rounded-full"></div>
    <div class="h-3 w-3 bg-black rounded-full"></div>
  </div>
  <div class="flex flex-col justify-between gap-3 p-4 flex-1">
    <main class="flex-1 flex flex-col gap-2">
      <h4 class="text-md md:text-lg font-medium font-fantabular">
        {title}
      </h4>
      <span
        class="text-primary block font-medium text-base font-fantabular italic"
        >{duration}</span
      >

      <ul class="space-y-1 list-disc list-outside pl-4">
        {
          descriptions &&
            descriptions.map((description) => (
              <li class="text-xs md:text-sm text-black text-pretty">
                {description}
              </li>
            ))
        }
      </ul>
    </main>
    <div
      class="border-2 border-[#cecdce] rounded-lg w-fit px-4 py-2 flex flex-row items-center gap-4"
    >
      <img
        src={logo}
        alt={`Logo de la institución ${institution}`}
        class="h-12"
      />
      <p class="text-black font-normal text-sm font-fantabular italic">
        {institution}
      </p>
    </div>
  </div>
</article>
