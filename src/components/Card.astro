---
import { type Proyect } from "@/models";
import { Icon } from "astro-icon/components";

interface Props extends Proyect {
  section: "UX" | "Front";
}
const { slug, name, description, imageUrl, tags } = Astro.props;

let { section } = Astro.props;
---

<a href={`/proyectos/${slug}`} target="_blank" class="inline-block">
  <article
    class={`group cursor-pointer flex flex-col border-2 border-black rounded-xl md:rounded-2xl overflow-hidden h-96 w-[480px]  md:min-h-[240px] bg-white`}
  >
    <div
      class="h-10 py-4 flex flex-row items-center gap-2 px-4 border-b-4 border-black"
    >
      <div class="h-3 w-3 bg-black rounded-full"></div>
      <div class="h-3 w-3 bg-black rounded-full"></div>
      <div class="h-3 w-3 bg-black rounded-full"></div>
    </div>
      <header
        class="border-b-2 border-black h-1/3 w-full bg-[url(/fondo.svg)]  bg-[length:20px] overflow-hidden md:flex-shrink-0"
      >
        <img
          src={imageUrl}
          alt={"Portada del proyecto " + name}
          class="w-full h-full object-cover md:object-contain transition-transform duration-300 group-hover:scale-110 bg-primary/10"
        />
      </header>
      <main
        class="flex flex-col gap-2 p-4 justify-between w-full md:flex-1"
      >
        <h4 class="text-md md:text-lg font-semibold">{name}</h4>
        <div class="flex flex-wrap gap-2">
          {
            tags &&
              tags.map((tag) => (
                <div class="bg-secondary text-black border border-black py-0.5 px-2 md:px-4 w-fit text-xs font-semibold">
                  {tag}
                </div>
              ))
          }
        </div>
        <p class="text-xs md:text-sm text-pretty line-clamp-3">{description}</p>
        <div>
          <button
            class="cursor-pointer
      border-2 border-black 
      px-3 py-2
      text-black font-medium text-sm
      flex items-center gap-1
      w-fit
      transition-colors duration-300 ease-in-out
      "
          >
            <Icon
              name="g-link"
              height={20}
              width={20}
              class="transition-transform ease-in-out duration-200 group-hover:rotate-45"
            />

            <span
              class="overflow-hidden font-semibold
        max-w-0
        opacity-0
        whitespace-nowrap
        transition-all duration-300 ease-in-out
        group-hover:max-w-[120px]
        group-hover:opacity-100"
            >
              Ver proyecto
            </span>
          </button>
        </div>
      </main>
  </article>
</a>
