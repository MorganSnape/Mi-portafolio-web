---
import { type Proyect } from '@/models'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

import TagDesign from '@/assets/tag-design.svg'
import TagFrontEnd from '@/assets/tag-code.svg'
import TagDesignUX from '@/assets/tag-ux-ui.svg'

interface Props extends Proyect {
  section: 'UX' | 'Front' | 'Diseño'
}

const { slug, descriptionProject, coverImage, tags, nameProject, section } =
  Astro.props

const icons = {
  UX: TagDesignUX,
  Front: TagFrontEnd,
  Diseño: TagDesign,
} as const

const SectionIcon = icons[section as keyof typeof icons] ?? TagDesign
---

<a href={`/proyectos/${slug}`} class="relative inline-block snap-start shrink-0">
  <SectionIcon
    class="absolute right-4 -top-2 w-16 h-16 z-40 drop-shadow-md"
  />
  <article
    class={` group flex flex-col border-2 border-black rounded-xl md:rounded-2xl h-[360px] md:h-[400px] w-[280px] md:w-xs bg-white`}
  >

    <div
      class="h-10 py-4 flex flex-row items-center gap-2 px-4 border-b-4 border-black"
    >
      <div class="h-3 w-3 bg-black rounded-full"></div>
      <div class="h-3 w-3 bg-black rounded-full"></div>
      <div class="h-3 w-3 bg-black rounded-full"></div>
    </div>
    <header
      class="relative w-full overflow-hidden md:flex-shrink-0 rounded-b-2xl shadow-md h-2/5"
    >
      <Image
        src={coverImage}
        alt={'Portada del proyecto ' + nameProject}
        class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-110"
        width={coverImage.width}
        height={coverImage.height}
      />
    </header>
    <main class="flex flex-col p-4 justify-between w-full flex-1">
      <h4 class="text-sm md:text-base font-medium font-fantabular">
        {nameProject}
      </h4>
      <p class="text-sm lg:text-base text-pretty line-clamp-3">
        {descriptionProject}
      </p>
      <div class="flex flex-row items-center justify-between">
        <div class="flex flex-wrap gap-2">
          {
            tags
              ?.slice(0, 1)
              .map(tag => (
                <div class="bg-secondary text-black border border-black py-0.5 px-2 md:px-4 w-fit text-xs font-semibold">
                  {tag}
                </div>
              ))
          }
        </div>
        <button
          class="cursor-pointer
      
      p-2
      font-medium text-sm
      flex items-center gap-4
      w-fit
      transition-colors duration-300 ease-in-out text-black"
        >
          <Icon
            name="fa6-solid:arrow-up"
            height={20}
            width={20}
            class="transition-transform ease-in-out duration-200 rotate-45 group-hover:rotate-90"
          />
        </button>
      </div>
    </main>
  </article>
</a>

<script>
  const button = document.getElementById('backToTop')

  button?.addEventListener('click', () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth',
    })
  })
</script>
