---
import { type Proyect } from "@/models";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

interface Props extends Proyect {
  section: "UX" | "Front"| "Diseño";
}

const {
  slug,
  descriptionProject,
  coverImage,
  tags,
  nameProject,
} = Astro.props;
---

<a
  href={`/proyectos/${slug}`}
  class="inline-block snap-start shrink-0"
>
  <article
    class={`group flex flex-col border-2 border-black rounded-xl md:rounded-2xl overflow-hidden h-[368px] w-64 sm:w-xs md:min-h-[240px] bg-white flex-shrink-0 mx-auto`}
  >
    <div
      class="h-10 py-4 flex flex-row items-center gap-2 px-4 border-b-4 border-black"
    >
      <div class="h-3 w-3 bg-black rounded-full"></div>
      <div class="h-3 w-3 bg-black rounded-full"></div>
      <div class="h-3 w-3 bg-black rounded-full"></div>
    </div>
    <header
      class="relative border-b-2 border-black h-1/3 w-full bg-black overflow-hidden md:flex-shrink-0"
    >
      <Image src={coverImage} alt={"Portada del proyecto " + nameProject}
        class="w-full h-full object-cover object-center transition-transform duration-300 group-hover:scale-110"
        width={coverImage.width}
        height={coverImage.height}
      />
    </header>
    <main class="flex flex-col gap-2 p-4 justify-between w-full md:flex-1">
      <h4 class="text-md md:text-lg font-semibold">{nameProject}</h4>
      <div class="flex flex-wrap gap-2">
        {
          tags
            ?.slice(0, 1)
            .map((tag) => (
              <div class="bg-secondary text-black border border-black py-0.5 px-2 md:px-4 w-fit text-xs font-semibold">
                {tag}
              </div>
            ))
        }
      </div>
      <p class="text-sm lg:text-base text-pretty line-clamp-3">
        {descriptionProject}
      </p>
      <div>
        <button
          class="cursor-pointer
      
      px-3 py-2
      font-medium text-sm
      flex items-center gap-4
      w-fit
      transition-colors duration-300 ease-in-out text-black rounded-lg"
        >
          <Icon
            name="fa6-solid:arrow-up"
            height={20}
            width={20}
            class="transition-transform ease-in-out duration-200 rotate-45 group-hover:rotate-90"
          />

          <span
            class="overflow-hidden font-semibold
        max-w-0
        opacity-0
        whitespace-nowrap
        transition-all duration-300 ease-in-out
        group-hover:max-w-[120px]
        group-hover:opacity-100"
          >
            Ver proyecto
          </span>
        </button>
      </div>
    </main>
  </article>
</a>

<script>
  const button = document.getElementById("backToTop");

  button?.addEventListener("click", () => {
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
  });
</script>