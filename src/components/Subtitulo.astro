---
interface Props {
  text?: string | null;
  type?: string | null;
  align: "left" | "center" | "right";
}

enum aligns {
  left = "left",
  center = "center",
  right = "right",
}

const { align, text, type } = Astro.props;
---

<div class="w-screen relative h-2 flex items-center">
  <h3
    class:list={aligns[align]}
    class="min-w-[18rem] md:min-w-sm absolute bottom-[100%] translate-y-1/2"
  >
    <div
      class={`bg-secondary w-full h-14 md:h-16 py-2 md:py-6 px-6 md:px-12 gap-4 text-center text-sm md:text-base ${align !== "center" ? "tag-me" : "center-tag-me"}`}
    >
      <span class="font-semibold">{text}</span>
      <span class="tracking-[6px] font-bold">{type}</span>
    </div>
  </h3>
  <div class="bg-black w-full h-2"></div>
</div>

<style>
  .left {
    left: 20px;
  }

  .center {
    transform: translateX(-50%);
    left: 50%;
  }
  .right {
    right: 20px;
  }

  @media screen and (min-width: 768px) {
    .left {
      left: 40px;
    }
    .right {
      right: 40px;
    }
  }
</style>
