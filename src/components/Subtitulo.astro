---
interface Props {
  text?: string | null;
  type?: string | null;
  align: "left" | "center" | "right";
}

enum aligns {
  left = "left",
  center = "center",
  right = "right",
}

const { align, text, type } = Astro.props;
---

<div class="w-full relative h-2 flex items-center">
  <h2
    class:list={aligns[align]}
    class={`min-w-[12rem] md:min-w-[18rem] lg:min-w-sm absolute bottom-[100%] translate-y-1/2 ${align === "center" && "-translate-1/2 left-1/2"} ${align === "left" && "left-5 md:left-20 lg:left-40"} ${align === "right" && "right-5 md:right-20 lg:right-40"} `}
  >
    <div
      class={`bg-secondary w-full h-14 md:h-16 py-2 md:py-6 px-5 md:px-12 gap-4 text-center text-base md:text-lg ${align !== "center" ? "tag-me" : "center-tag-me"}`}
    >
      {text && <span class="font-semibold">{text}</span>}
      <span class="tracking-[6px] font-bold">{type}</span>
    </div>
  </h2>
  <div class="bg-black w-full h-2"></div>
</div>
