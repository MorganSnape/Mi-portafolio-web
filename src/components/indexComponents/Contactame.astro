---
import Computador from "@/assets/Ilustraciones/Computador.svg";
---

<section
  id="contactame"
  class="w-full flex flex-col items-center text-black py-16 border-t-8 border-black"
>
  <div class=" w-full mx-auto max-w-[1280px] px-4 sm:px-12 xl:px-0">
    <!-- Header Section -->
    <div class="relative text-center py-12">
      <h2 class="titleH3 efectoResaltador text-balance">
        Cada gran proyecto empieza con una conversación.
      </h2>
      <p class="text-base lg:text-lg leading-relaxed mt-4">
        ¿Tienes una idea o necesitas ayuda con tu marca o web?<br />
        <strong>Estoy lista para ayudarte a hacerla realidad.</strong>
      </p>
      <div class="absolute -bottom-6 md:bottom-0 right-0 rotate-8 tag-me bg-tag lg:mx-0 py-2 text-base md:text-lg mx-auto w-44 md:w-52">
        <p class=" text-balance text-sm">¡Te responderé en menos de <span class="font-bold">24 horas</span>!</p>
      </div>
    </div>

    <div class="relative">
      <div class="lg:absolute lg:top-0 lg:right-0">
        <form id="contact-form" class="flex flex-col gap-4 p-6">
          <!-- Nombre y Correo en la misma fila -->
          <div class="flex flex-col md:flex-row gap-4 md:gap-4">
            <!-- Nombre Completo -->
            <div class="flex flex-col gap-2 flex-1">
              <label class="font-semibold text-sm">Nombre completo</label>
              <input
                name="fullName"
                type="text"
                required
                placeholder="Tu nombre completo"
                class="border border-black rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary text-sm"
              />
            </div>

            <!-- Correo Electrónico -->
            <div class="flex flex-col gap-2 flex-1">
              <label class="font-semibold text-sm">Correo electrónico</label>
              <input
                name="fromEmail"
                type="email"
                required
                placeholder="tu@email.com"
                class="border border-black rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary text-sm"
              />
            </div>
          </div>
          <!-- Mensaje del Proyecto -->
          <div class="flex flex-col gap-2 w-full">
            <label class="font-semibold text-sm"
              >Cuéntame sobre tu proyecto...</label
            >
            <textarea
              name="message"
              required
              rows="5"
              placeholder="Describe tu idea, necesidades y objetivos..."
              class="border border-black rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary text-sm resize-none w-full"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <div class="flex justify-end w-full">
            <button
              type="submit"
              class="primaryButton border-2 text-white flex flex-row items-center gap-2 px-4 py-3 text-sm md:px-6 md:py-3 md:text-base font-normal bg-primary"
            >
              Enviar mensaje
            </button>
          </div>
        </form>
      </div>
      <Computador class="w-full md:w-4/5 max-w-[800px]"  />
    </div>
  </div>

  <script>
    function sendContactMail(event: SubmitEvent) {
      event.preventDefault();
      const form = event.currentTarget as HTMLFormElement;
      const fullName = (form.fullName?.value || "").trim();
      const fromEmail = (form.fromEmail?.value || "").trim();
      const message = (form.message?.value || "").trim();

      if (!fullName || !fromEmail || !message) {
        alert("Por favor completa todos los campos del formulario.");
        return;
      }

      const emailBody = `
Nuevo contacto desde el portafolio:

Nombre: ${fullName}
Correo: ${fromEmail}

Detalles del proyecto:
${message}
      `.trim();

      const subject = encodeURIComponent(
        `Nuevo contacto desde portafolio: ${fullName}`,
      );
      const body = encodeURIComponent(emailBody);
      const mailto = `mailto:gabriellangeles@outlook.com?subject=${subject}&body=${body}`;

      window.location.href = mailto;
    }

    const formElement = document.getElementById("contact-form");
    if (formElement) {
      formElement.addEventListener("submit", sendContactMail);
    }
  </script>
</section>
