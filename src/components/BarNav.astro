---
import { Icon } from "astro-icon/components";
import Logo from "public/isotipo-negativo.svg";

const links = [
  {
    name: "Inicio",
    href: "#inicio",
  },
  {
    name: "Sobre mí",
    href: "#sobre-mi",
  },
  {
    name: "Experiencia",
    href: "#experiencia-container",
  },
  {
    name: "Proyectos",
    href: "#proyectos-container",
  },
  {
    name: "Estudios",
    href: "#estudios-container",
  },
  {
    name: "Contáctame",
    href: "#contactame",
  },
  {
    name: "Currículum",
    href: "/curriculum",
  },
];
---

<header class="fixed inset-x-0 top-0 z-50 bg-black-secondary">
  <nav class="max-w-[1440px] mx-auto flex items-center justify-between px-4 md:px-6 h-[var(--altura-header)] font-rethink">

    <!-- Logo -->
    <Logo class="h-8 w-auto fill-white pointer-events-none" />

    <!-- Botón hamburguesa -->
    <label for="menu-hamburguer" class="md:hidden cursor-pointer z-50">
      <Icon name="codicon:menu" class="text-3xl text-white" />
    </label>
    <input type="checkbox" id="menu-hamburguer" class="hidden peer" />

    <!-- Links -->
    <ul
      class="fixed md:static inset-x-0 top-[var(--altura-header)] md:top-0 bg-black-secondary md:bg-transparent
      flex flex-col md:flex-row items-center md:items-center
      max-h-0 peer-checked:max-h-screen md:max-h-none overflow-hidden md:overflow-visible
      transition-all duration-300"
    >
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-item font-rethink px-4 py-3 md:py-2 text-white text-base font-normal
              hover:text-gray-400
              active:font-semibold
              focus:outline-none focus:ring-2 focus:ring-yellow-300"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const $ul = document.querySelector("header ul.ul-links");
  const $checkbox = document.getElementById(
    "menu-hamburguer",
  ) as HTMLInputElement;
  const $navItems = document.querySelectorAll(
    ".nav-item",
  ) as NodeListOf<HTMLAnchorElement>;

  // Cerrar menu al hacer click
  $ul?.addEventListener("click", () => {
    $checkbox.checked = false;
  });

  // Función para resaltar nav item activo
  function updateActiveNavItem() {
    const sections = document.querySelectorAll(
      "section[id]",
    ) as NodeListOf<HTMLElement>;
    let currentSection = "inicio";

    sections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      if (
        rect.top <= window.innerHeight / 2 &&
        rect.bottom >= window.innerHeight / 2
      ) {
        currentSection = section.id;
      }
    });

    $navItems.forEach((item) => {
      item.classList.remove("active");
      const href = item.getAttribute("href");
      if (
        href === `#${currentSection}` ||
        (currentSection === "inicio" && href === "#inicio")
      ) {
        item.classList.add("active");
      }
    });
  }

  // Listener en scroll
  window.addEventListener("scroll", updateActiveNavItem);
  // Inicializar al cargar
  updateActiveNavItem();
</script>

<style>
  .nav-item:active {
    font-weight: 600;
    color: white;
    border:none;
  }

  .nav-item:focus {
    outline: none;
  }

  .nav-item.active {
    font-weight: 700;
    color: var(--color-secondary, #ffe971);
    border-bottom: 3px solid var(--color-secondary, #ffe971);
  }
</style>
