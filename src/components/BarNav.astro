---
import { Icon } from "astro-icon/components";
import Logo from "public/isotipo-negativo.svg";
---

<header class="fixed right-0 z-40 w-screen bg-black-secondary">
  <nav
    class="font-rethink flex flex-row justify-between items-center lg:gap-8 px-6 max-w-[1440px] mx-auto"
  >
  <Logo class="fill-white h-4/5"/>

    <label for="menu-hamburguer" class="label-hamburguer">
      <Icon name="codicon:menu" class="text-3xl text-white" />
    </label>
    <input type="checkbox" name="" id="menu-hamburguer" />

    <ul
      class="ul-links flex flex-col md:flex-row justify-center items-center gap-2"
    >
      <li class="li-link">
        <a href="#inicio" class="nav-item">Inicio</a>
      </li>
      <li class="li-link">
        <a href="#sobre-mi" class="nav-item">Sobre mí</a>
      </li>
      <li class="li-link">
        <a href="#experiencia-container" class="nav-item">Experiencia</a>
      </li>
      <li class="li-link">
        <a href="#proyectos-container" class="nav-item">Proyectos</a>
      </li>
      <li class="li-link">
        <a href="#estudios-container" class="nav-item">Estudios</a>
      </li>
      <li class="li-link">
        <a href="#contactame" class="nav-item">Contáctame</a>
      </li>
      <li class="li-link">
        <a href="/curriculum" class="nav-item">Currículum</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const $ul = document.querySelector("header ul.ul-links");
  const $checkbox = document.getElementById(
    "menu-hamburguer",
  ) as HTMLInputElement;
  const $navItems = document.querySelectorAll(
    ".nav-item",
  ) as NodeListOf<HTMLAnchorElement>;

  // Cerrar menu al hacer click
  $ul?.addEventListener("click", () => {
    $checkbox.checked = false;
  });

  // Función para resaltar nav item activo
  function updateActiveNavItem() {
    const sections = document.querySelectorAll(
      "section[id]",
    ) as NodeListOf<HTMLElement>;
    let currentSection = "inicio";

    sections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      if (
        rect.top <= window.innerHeight / 2 &&
        rect.bottom >= window.innerHeight / 2
      ) {
        currentSection = section.id;
      }
    });

    $navItems.forEach((item) => {
      item.classList.remove("active");
      const href = item.getAttribute("href");
      if (
        href === `#${currentSection}` ||
        (currentSection === "inicio" && href === "#inicio")
      ) {
        item.classList.add("active");
      }
    });
  }

  // Listener en scroll
  window.addEventListener("scroll", updateActiveNavItem);
  // Inicializar al cargar
  updateActiveNavItem();
</script>

<style>
  nav {
    height: var(--altura-header);
  }

  .nav-item {
    z-index: 4;
    list-style: none;
    font-size: 16px;
    font-weight: 400;
    color: white;
    cursor: pointer;
    padding: 4px 16px;
    border: 2px solid transparent;
    transition: transform 0.1s ease-in-out;
  }

  .nav-item:hover {
    transform: scale(1.03);
    color: #9d9a9d;
  }

  .nav-item:active {
    font-weight: 600;
    color: white;
  }

  .nav-item.active {
    font-weight: 700;
    color: var(--color-secondary, #ffe971);
    border-bottom: 3px solid var(--color-secondary, #ffe971);
  }

  .label-hamburguer,
  #menu-hamburguer {
    display: none;
  }

  /*Vista movil*/

  @media (max-width: 890px) {
    .label-hamburguer,
    #menu-hamburguer {
      display: contents;
    }
    nav {
      position: relative;
      flex-wrap: wrap;
    }
    .ul-links {
      width: 100%;
      position: absolute;
      left: 0;
      top: var(--altura-header);
      background: var(--color-black-secondary);

      justify-content: flex-start;

      height: 0;
      padding-left: 0px;
      margin: 0px;
      overflow: hidden;

      transition: all 0.3s;
    }

    .li-link {
      width: 100%;
    }

    

    .li-link:nth-child(2n) {
      background-color: #2d2a2d;
    }

    .nav-item {
      display: block;
      width: 100%;
      padding: 16px 0px;
      font-size: 20px;
      text-align: center;
    }

    #menu-hamburguer:checked + .ul-links {
      height: calc(100vh - var(--altura-header));
    }
  }
</style>
