---
import { Icon } from "astro-icon/components";
import Logo from "public/isotipo-negativo.svg";

import {navLinks} from "@/data/navLinks";

---

<header class="fixed top-0 z-50 bg-black-secondary w-full">
  <nav class="max-w-[1440px] mx-auto flex items-center justify-between px-4 md:px-6 h-[var(--altura-header)]">
    <Logo class="h-8 fill-white" />

    <!-- Botón hamburguesa -->
    <label for="menu-hamburguer" class="md:hidden z-50">
      <Icon name="codicon:menu" class="text-3xl text-white" />
    </label>
    <input type="checkbox" id="menu-hamburguer" class="hidden peer" />

    <!-- Links -->  
    <ul
      class="fixed md:static inset-x-0 left-0 right-0 top-[var(--altura-header)] bottom-0 md:bottom-auto md:top-0 bg-black-secondary md:bg-transparent
      flex flex-col md:flex-row items-center md:items-center justify-start peer-checked:justify-center max-h-0 peer-checked:max-h-none overflow-hidden md:overflow-visible transition-all duration-300 ul-links box-border px-0 h-full md:h-auto space-y-4 md:space-y-0 md:space-x-4"
    >
      {
        navLinks.map((link) => (
          <li class="w-full md:w-fit">
            <a
              href={link.href}
              class="nav-item font-rethink w-full px-4 text-center md:text-left text-white text-base font-normal hover:text-gray-400 focus:ring-2 active:font-semibold active:text-white active:border-none focus:outline-none h-[calc(var(--altura-header)_-_12px)] focus:ring-yellow-300 flex flex-col items-center justify-center"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const $ul = document.querySelector("header ul.ul-links");
  const $checkbox = document.getElementById(
    "menu-hamburguer",
  ) as HTMLInputElement;
  const $navItems = document.querySelectorAll(
    ".nav-item",
  ) as NodeListOf<HTMLAnchorElement>;

  // Cerrar menu al hacer click
  $ul?.addEventListener("click", () => {
    $checkbox.checked = false;
  });

  // Función para resaltar nav item activo
  function updateActiveNavItem() {
    const sections = document.querySelectorAll(
      "section[id]",
    ) as NodeListOf<HTMLElement>;
    let currentSection = "inicio";

    sections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      if (
        rect.top <= window.innerHeight / 2 &&
        rect.bottom >= window.innerHeight / 2
      ) {
        currentSection = section.id;
      }
    });

    $navItems.forEach((item) => {
      item.classList.remove("active");
      const href = item.getAttribute("href");
      if (
        href === `#${currentSection}` ||
        (currentSection === "inicio" && href === "#inicio")
      ) {
        item.classList.add("active");
      }
    });
  }

  // Listener en scroll
  window.addEventListener("scroll", updateActiveNavItem);
  // Inicializar al cargar
  updateActiveNavItem();
</script>

<style>
  .nav-item.active {
    font-weight: 700;
    color: var(--color-secondary, #ffe971);
    border-bottom: 3px solid var(--color-secondary, #ffe971);
  }
</style>
