---
import { Icon } from "astro-icon/components";

const { detailName, content, icon } = Astro.props;
---

<li class="flex flex-col">
  <div class="flex flex-row items-center gap-2 font-semibold">
    <Icon name={icon} class="text-lg md:text-xl" />
    {detailName}
  </div>
  <p class="ml-7">
    {content}
  </p>
</li>
