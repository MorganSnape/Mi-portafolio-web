---
type StyleType = "transparent" | "solid";

interface Props {
  id?: string;
  style: StyleType;
  text?: string;
  typeIcon?: boolean;
  href: string;
}

const { style, text, typeIcon, href, id } = Astro.props;

const animation = `hover:scale-105 disabled:hover:scale-100 transition-all duration-150 ease-in-out select-none translate-0 active:translate-1.5`;

const shadowSolid =
  "border-black shadow-[4px_4px_0px_#0a080a] md:shadow-[6px_6px_0px_#0a080a] active:shadow-[0px_0px_0px_#0a080a]";
const shadowTransparent =
  "border-white shadow-[4px_4px_0px_#ffffff] md:shadow-[6px_6px_0px_#ffffff] active:shadow-[0px_0px_0px_#ffffff]";
---

<a
  id={id}
  href={href}
  class={`${animation} primaryButton border-2 text-white flex flex-row items-center gap-2 px-4 py-3 text-sm md:px-6 md:py-3 md:text-base font-normal ${style === "solid" ? `bg-primary ${shadowSolid}` : `bg-transparent ${shadowTransparent}`}`}
>
  {text && <span>{text}</span>}
  {typeIcon &&<span class="flex items-center stroke-white"><slot/></span> }
</a>
